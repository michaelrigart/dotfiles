#!/usr/bin/env zsh
# Custom shell functions

# op-edit — edit a 1Password-backed dotfile, then re-apply the chezmoi targets
# that render from it.
#
# Some dotfiles keep their contents in a 1Password secure note instead of the
# public dotfiles repo, rendered by chezmoi with:
#     {{ onepasswordRead "op://<vault>/<item>/notes" }}
# e.g. ~/.ssh/config.
#
# Usage:
#   op-edit                  # list op-backed dotfiles (file ⇐ 1Password item)
#   op-edit ~/.ssh/config    # by file path — resolves the note automatically
#   op-edit "SSH config"     # or by 1Password item name
#
# The note is written to a private temp file (mode 600) while editing and passed
# to `op item edit` as an argument (briefly visible via `ps`).
op-edit() {
  emulate -L zsh
  local src; src="$(chezmoi source-path)" || return 1

  # No argument: list op-backed dotfiles as "file ⇐ item".
  if [[ -z "$1" ]]; then
    print -r -- "op-edit <file|item> — 1Password-backed dotfiles:"
    local f r i t
    while IFS= read -r f; do
      r="$(grep -m1 -oE 'op://[^"]+/notes' "$f" 2>/dev/null)" || continue
      [[ -n "$r" ]] || continue
      i="${${r#op://*/}%/notes}"
      t="$(chezmoi target-path "$f" 2>/dev/null)"
      printf '  %-30s ⇐  %s\n' "${t/#$HOME/~}" "$i"
    done < <(grep -rlE 'op://[^"]+/notes' "$src" --include='*.tmpl' 2>/dev/null) | sort -u
    return 0
  fi

  # Resolve the argument to an op reference: a managed file path, or an item name.
  local arg="${1/#\~/$HOME}" srcfile ref
  if srcfile="$(chezmoi source-path "$arg" 2>/dev/null)"; then
    ref="$(grep -m1 -oE 'op://[^"]+' "$srcfile" 2>/dev/null)"
    if [[ -z "$ref" ]]; then
      print -ru2 -- "op-edit: '$1' is chezmoi-managed but not backed by a 1Password note."
      return 1
    fi
  else
    ref="op://Private/$1/notes"
  fi

  # Parse op://<vault>/<item>/<field>.
  local rest="${ref#op://}"
  local vault="${rest%%/*}"; rest="${rest#*/}"
  local item="${rest%/*}" field="${rest##*/}"
  if [[ "$field" != "notes" ]]; then
    print -ru2 -- "op-edit: '$1' maps to op field '$field', not a note — edit it in 1Password directly."
    return 1
  fi

  # Pull current note content into a private temp file.
  local tmp; tmp="$(mktemp -t op-edit)" || return 1
  if ! op read "$ref" >| "$tmp" 2>/dev/null; then
    print -ru2 -- "op-edit: can't read $ref — does '$item' exist in '$vault'?"
    rm -f "$tmp"; return 1
  fi

  # Edit; bail out if nothing changed.
  local before; before="$(shasum "$tmp" | awk '{print $1}')"
  "${EDITOR:-nvim}" "$tmp"
  if [[ "$before" == "$(shasum "$tmp" | awk '{print $1}')" ]]; then
    print -r -- "op-edit: no changes to '$item'."
    rm -f "$tmp"; return 0
  fi

  # Push the edited content back to the note.
  if ! op item edit "$item" --vault "$vault" "notesPlain=$(<"$tmp")" >/dev/null; then
    print -ru2 -- "op-edit: failed to update '$item'."
    rm -f "$tmp"; return 1
  fi
  rm -f "$tmp"

  # Re-apply every chezmoi target that renders from this note.
  local -a targets=()
  local f t
  while IFS= read -r f; do
    [[ -n "$f" ]] || continue
    t="$(chezmoi target-path "$f" 2>/dev/null)"
    [[ -n "$t" ]] && targets+=("$t")
  done < <(grep -rlF "op://$vault/$item/" "$src" --include='*.tmpl' 2>/dev/null)

  if (( ${#targets} )); then
    chezmoi apply "${targets[@]}" \
      && print -r -- "✓ '$item' updated → applied: ${targets[*]/#$HOME/~}"
  else
    print -r -- "✓ '$item' updated."
  fi
}

# tsh — Teleport SSH with a portable TERM. Ghostty's ssh-env/ssh-terminfo cover
# the plain `ssh` binary, but not `tsh`, and edge nodes lack xterm-ghostty
# terminfo. Only the `ssh` subcommand needs the downgrade; other subcommands
# (tsh login, kube, db, …) run untouched.
tsh() {
  if [[ "$1" == "ssh" ]]; then
    TERM=xterm-256color command tsh "$@"
  else
    command tsh "$@"
  fi
}

# dev — open (or return to) a project in its Zellij "dev" layout.
#   dev                  pick from all repos under ~/Code (fzf)
#   dev curato           by name: exact basename → case-insensitive substring → fzf
#   dev Netronix/curato  path relative to ~/Code
#   dev .                the git repo containing the current directory
#
# Session name = the repo's path under ~/Code, lowercased, "/" → "--" (Zellij
# rejects "/"). Repos outside ~/Code, over-length names, or worktrees get a short
# hash of the canonical git root appended to stay unique and within Zellij's limit.
dev() {
  emulate -L zsh
  setopt local_options null_glob extended_glob

  local code="$HOME/Code" repo name arg="$1"
  local -a repos=( "$code"/*/.git(N:h) "$code"/*/*/.git(N:h) )

  # 1) "." or an existing directory → the git repo that contains it
  if [[ "$arg" == "." || ( -n "$arg" && -d "$arg" ) ]]; then
    repo="$(git -C "${arg:-$PWD}" rev-parse --show-toplevel 2>/dev/null)" \
      || { print -ru2 -- "dev: '${arg:-$PWD}' is not inside a git repo."; return 1; }

  # 2) exact path relative to ~/Code (e.g. Netronix/curato)
  elif [[ -n "$arg" && -e "$code/$arg/.git" ]]; then
    repo="$code/$arg"

  # 3) by name, or the fzf picker
  else
    local -a hits
    if [[ -z "$arg" ]]; then
      hits=( $repos )
    else
      hits=( ${(M)repos:#*/$arg} )                        # exact basename
      (( ${#hits} )) || hits=( ${(M)repos:#(#i)*$arg*} )  # case-insensitive substring
    fi
    if (( ${#hits} == 1 )); then
      repo="${hits[1]}"
    else
      local -a pool; (( ${#hits} )) && pool=( $hits ) || pool=( $repos )
      local sel
      sel="$(print -rl -- ${pool[@]#$code/} | fzf --prompt='dev > ' ${arg:+--query=$arg})" || return 0
      [[ -n "$sel" ]] || return 0
      repo="$code/$sel"
    fi
  fi

  repo="${repo:A}"
  [[ -n "$repo" && -e "$repo/.git" ]] || { print -ru2 -- "dev: no git repo resolved."; return 1; }

  # --- session name ---
  if [[ "$repo" == "$code/"* ]]; then
    local slug="${repo#$code/}"; slug="${slug//\//--}"; name="${(L)slug}"
    if (( ${#name} > 36 )); then
      local h; h="$(shasum -a 256 <<<"$repo")"; name="${name[1,26]}--${h[1,8]}"
    fi
  else
    local h; h="$(shasum -a 256 <<<"$repo")"; name="${repo:t:l}--${h[1,8]}"
  fi

  # --- launch / attach / switch ---
  local exists=
  zellij list-sessions -s 2>/dev/null | grep -Fqx -- "$name" && exists=1
  if [[ -n "$ZELLIJ" ]]; then
    if [[ -n "$exists" ]]; then
      zellij action switch-session "$name"
    else
      zellij action switch-session "$name" --layout dev --cwd "$repo"
    fi
  elif [[ -n "$exists" ]]; then
    zellij attach "$name"
  else
    ( cd "$repo" && zellij --session "$name" --new-session-with-layout dev )
  fi
}
