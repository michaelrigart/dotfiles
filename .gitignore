# Sensitive files (extra safety layer)
# Note: SSH keys and secrets should use templates with 1Password
# but this prevents accidental commits of any credentials
**/id_rsa
**/id_ed25519
**/id_ecdsa
**/*.pem
**/secrets.yml
**/secrets.yaml
**/.env
**/.env.*
!**/.env.example
!**/.env.template

# Logs
*.log

# Backup files from editors
*~
\#*\#
.\#*

# Chezmoi state files (shouldn't be in source, but just in case)
.chezmoidata.toml
.chezmoidata.yaml
.chezmoidata.json
